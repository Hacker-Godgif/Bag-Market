<%- include('./partials/header') %>
    <div class="w-full min-h-screen flex items-start px-20 py-28 gap-10 bg-zinc-50">
        <!-- Left: Cart Items -->
        <div class="w-[65%] flex flex-col gap-6">
            <% if (typeof user !== 'undefined' && user.cart && user.cart.length > 0) { %>
                <% user.cart.forEach(function(item){ %>
                    <div class="w-full flex rounded-lg overflow-hidden border border-zinc-200 bg-white shadow-sm">
                        <!-- Left inside card: Image -->
                        <div class="w-48 h-48 flex items-center justify-center" style="background-color: <%= item.bgcolor || '#f3f4f6' %>;">
                            <% if (item.image) { %>
                                <img class="h-32 object-contain" src="data:image/jpeg;base64,<%= typeof item.image === 'string' ? item.image : item.image.toString('base64') %>" alt="">
                            <% } else { %>
                                <div class="text-zinc-400 text-sm">No Image</div>
                            <% } %>
                        </div>
                        <!-- Right inside card: Info & Quantity controls -->
                        <div class="flex-1 flex flex-col justify-between p-6" style="background-color: <%= item.panelcolor || '#ffffff' %>; color: <%= item.textcolor || '#1f2937' %>;">
                            <div class="flex justify-between items-start">
                                <div>
                                    <h3 class="text-2xl font-semibold"><%= item.name %></h3>
                                    <h4 class="text-lg mt-1">₹ <%= item.price %></h4>
                                </div>
                                <div class="flex items-center gap-2">
                                    <a href="/users/cart/add/<%= item._id %>" class="w-8 h-8 bg-zinc-100 hover:bg-zinc-200 flex rounded-full items-center justify-center text-zinc-900 transition-colors">
                                        <i class="ri-add-line"></i>
                                    </a>
                                    <div class="px-3 py-1 rounded-md bg-zinc-100 text-zinc-900 font-semibold">1</div>
                                    <a href="/users/cart/remove/<%= item._id %>" class="w-8 h-8 bg-zinc-100 hover:bg-zinc-200 flex rounded-full items-center justify-center text-zinc-900 transition-colors">
                                        <i class="ri-subtract-line"></i>
                                    </a>
                                </div>
                            </div>
                            <div class="flex justify-between items-center mt-4">
                                <span class="text-sm opacity-80">Net Total</span>
                                <span class="text-lg font-bold">₹ <%= item.price %></span>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <!-- Mock Card when cart is empty -->
                <div class="w-full flex rounded-lg overflow-hidden border border-zinc-200 bg-white shadow-sm">
                    <div class="w-48 h-48 bg-yellow-500 flex items-center justify-center">
                        <i class="ri-shopping-bag-3-line text-white text-6xl"></i>
                    </div>
                    <div class="flex-1 flex flex-col justify-between p-6 bg-zinc-900 text-white">
                        <div class="flex justify-between items-start">
                            <div>
                                <h3 class="text-2xl font-semibold">Clinge Bag</h3>
                                <h4 class="text-lg mt-1">₹ 1200</h4>
                            </div>
                            <div class="flex items-center gap-2">
                                <button class="w-8 h-8 bg-white/20 hover:bg-white/30 flex rounded-full items-center justify-center text-white transition-colors">
                                    <i class="ri-add-line"></i>
                                </button>
                                <div class="px-3 py-1 rounded-md bg-white text-zinc-900 font-semibold">01</div>
                                <button class="w-8 h-8 bg-white/20 hover:bg-white/30 flex rounded-full items-center justify-center text-white transition-colors">
                                    <i class="ri-subtract-line"></i>
                                </button>
                            </div>
                        </div>
                        <div class="flex justify-between items-center mt-4">
                            <span class="text-sm opacity-80">Net Total</span>
                            <span class="text-lg font-bold">₹ 1200</span>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>

        <!-- Right: Price Breakdown -->
        <div class="w-[35%] bg-white p-8 rounded-lg border border-zinc-200 shadow-sm flex flex-col justify-between">
            <div>
                <h3 class="text-xl font-bold text-zinc-800 mb-6 border-b pb-4">Price Breakdown</h3>
                <div class="space-y-4">
                    <div class="flex justify-between text-zinc-600">
                        <span>Total MRP</span>
                        <span>₹ <%= typeof bill !== 'undefined' ? bill : '1920' %></span>
                    </div>
                    <div class="flex justify-between text-zinc-600">
                        <span>Discount on MRP</span>
                        <span class="text-green-600">- ₹ 0</span>
                    </div>
                    <div class="flex justify-between text-zinc-600">
                        <span>Platform Fee</span>
                        <span>₹ 20</span>
                    </div>
                    <div class="flex justify-between text-zinc-600">
                        <span>Shipping Fee</span>
                        <span class="text-green-600 font-medium">FREE</span>
                    </div>
                </div>
                <hr class="my-6 border-zinc-200">
                <div class="flex justify-between items-center">
                    <h3 class="text-xl font-bold text-zinc-800">Total Amount</h3>
                    <h3 class="text-2xl font-bold text-green-600">₹ <%= typeof bill !== 'undefined' ? (Number(bill) + 20) : '1940' %></h3>
                </div>
            </div>
            <button class="w-full py-4 mt-8 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition shadow-md hover:shadow-lg flex items-center justify-center gap-2">
                <i class="ri-secure-payment-line"></i> Proceed to Checkout
            </button>
        </div>
    </div>
    <%- include('./partials/footer') %>