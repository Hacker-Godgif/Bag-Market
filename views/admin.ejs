<%- include('./partials/header') %>
    <div class="w-full min-h-screen flex items-start px-20 py-28 bg-zinc-50">
        <div class="w-[25%] flex flex-col items-start">
            <div class="flex flex-col gap-2">
                <a class="block w-fit mb-2 font-semibold text-blue-600" href="/owners/admin">All Products</a>
                <a class="block w-fit mb-2 text-zinc-600 hover:text-blue-600 transition" href="/products/create">Create new product</a>
            </div>
        </div>
        <div class="w-[75%] flex flex-col gap-6">
            <a class="text-red-600 font-medium hover:text-red-700 transition w-fit" href="/products/deleteall">Delete all</a>
            <div class="flex flex-wrap gap-6">
                <% if (typeof products !== 'undefined' && products.length > 0) { %>
                    <% products.forEach(function(product){ %>
                        <div class="w-60 rounded-xl overflow-hidden border border-zinc-200 shadow-sm bg-white hover:shadow-md transition">
                            <div class="w-full h-52 flex items-center justify-center relative group" style="background-color: <%= product.bgcolor || '#f3f4f6' %>;">
                                <% if (product.image) { %>
                                    <img class="h-[10rem] object-contain group-hover:scale-105 transition-transform duration-300" src="data:image/jpeg;base64,<%= typeof product.image === 'string' ? product.image : product.image.toString('base64') %>" alt="">
                                <% } else { %>
                                    <div class="text-zinc-400 text-sm">No Image</div>
                                <% } %>
                                <% if (product.discount > 0) { %>
                                    <span class="absolute top-3 right-3 bg-red-500 text-white text-xs font-bold px-2.5 py-1 rounded-full shadow-sm">
                                        -₹<%= product.discount %>
                                    </span>
                                <% } %>
                            </div>
                            <div class="flex justify-between items-center px-5 py-5" style="background-color: <%= product.panelcolor || '#ffffff' %>; color: <%= product.textcolor || '#1f2937' %>;">
                                <div>
                                    <h3 class="font-bold text-base tracking-tight"><%= product.name %></h3>
                                    <h4 class="text-sm font-semibold opacity-90 mt-0.5">₹ <%= product.price %></h4>
                                </div>
                                <a class="w-8 h-8 flex items-center justify-center rounded-full bg-white text-zinc-950 hover:bg-zinc-100 transition-colors shadow-sm" href="/users/cart/add/<%= product._id %>">
                                    <i class="ri-add-line"></i>
                                </a>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <!-- Fallback beautifully designed mock cards -->
                    <% [1, 2, 3, 4].forEach(function(index) { %>
                        <div class="w-60 rounded-xl overflow-hidden border border-zinc-200 shadow-sm bg-white hover:shadow-md transition">
                            <div class="w-full h-52 flex items-center justify-center bg-zinc-100 relative group">
                                <i class="ri-shopping-bag-3-line text-zinc-400 text-5xl"></i>
                                <span class="absolute top-3 right-3 bg-blue-500 text-white text-xs font-semibold px-2 py-0.5 rounded shadow-sm">Sample</span>
                            </div>
                            <div class="flex justify-between items-center px-5 py-5 bg-white text-zinc-800">
                                <div>
                                    <h3 class="font-bold text-base tracking-tight">Clinge Bag</h3>
                                    <h4 class="text-sm font-semibold text-zinc-500 mt-0.5">₹ 1200</h4>
                                </div>
                                <a class="w-8 h-8 flex items-center justify-center rounded-full bg-zinc-100 hover:bg-zinc-200 transition text-zinc-850 shadow-sm" href="">
                                    <i class="ri-add-line"></i>
                                </a>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </div>
    <%- include('./partials/footer') %>