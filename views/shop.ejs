<%- include('./partials/header') %>
    <div class="w-full min-h-screen flex items-start px-20 py-28 bg-zinc-50">
        <div class="w-[25%] flex flex-col items-start">
            <div class="flex items-center gap-2">
                <h3 class="text-zinc-600 font-medium">sort by</h3>
                <form action="/shop">
                    <select class="border-[1px] px-2 py-1 rounded bg-white text-sm" name="sortby" id="">
                        <option value="popular">Popular</option>
                        <option value="newest">Newest</option>
                    </select>
                </form>
            </div>
            <div class="flex flex-col mt-16 gap-1">
                <a class="block w-fit text-sm text-zinc-600 hover:text-blue-600 transition" href="">New Collection</a>
                <a class="block w-fit text-sm text-zinc-800 font-semibold" href="">All Products</a>
                <a class="block w-fit text-sm text-zinc-600 hover:text-blue-600 transition" href="">Discounted Products</a>
            </div>
            <div class="mt-20 flex flex-col gap-1">
                <span class="block w-fit text-xs font-bold uppercase tracking-wider text-zinc-400 mb-2">Filter by :</span>
                <a class="block w-fit text-sm text-zinc-600 hover:text-blue-600 transition" href="">Availability</a>
                <a class="block w-fit text-sm text-zinc-600 hover:text-blue-600 transition" href="">Discount</a>
            </div>
        </div>
        <div class="w-[75%] flex flex-col gap-6">
            <div class="flex flex-wrap gap-6">
                <% if (typeof products !== 'undefined' && products.length > 0) { %>
                    <% products.forEach(function(product){ %>
                        <div class="w-60 rounded-xl overflow-hidden border border-zinc-200 shadow-sm bg-white hover:shadow-md transition">
                            <div class="w-full h-52 flex items-center justify-center relative group" style="background-color: <%= product.bgcolor || '#f3f4f6' %>;">
                                <% if (product.image) { %>
                                    <img class="h-[10rem] object-contain group-hover:scale-105 transition-transform duration-300" src="data:image/jpeg;base64,<%= typeof product.image === 'string' ? product.image : product.image.toString('base64') %>" alt="<%= product.name %>">
                                <% } else { %>
                                    <div class="text-zinc-400 text-sm">No Image</div>
                                <% } %>
                                <% if (product.discount > 0) { %>
                                    <span class="absolute top-3 right-3 bg-red-500 text-white text-xs font-bold px-2.5 py-1 rounded-full shadow-sm">
                                        -₹<%= product.discount %>
                                    </span>
                                <% } %>
                            </div>
                            <div class="flex justify-between items-center px-5 py-5" style="background-color: <%= product.panelcolor || '#ffffff' %>; color: <%= product.textcolor || '#1f2937' %>;">
                                <div>
                                    <h3 class="font-bold text-base tracking-tight">
                                        <%= product.name %>
                                    </h3>
                                    <h4 class="text-sm font-semibold opacity-90 mt-0.5">₹ <%= product.price %>
                                    </h4>
                                </div>
                                <a class="w-8 h-8 flex items-center justify-center rounded-full bg-white text-zinc-950 hover:bg-zinc-100 transition-colors shadow-sm animate-pulse-subtle" href="/users/cart/add/<%= product._id %>">
                                    <i class="ri-add-line"></i>
                                </a>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="w-full py-20 flex flex-col items-center justify-center bg-white rounded-xl border border-zinc-200 shadow-sm">
                        <i class="ri-shopping-bag-3-line text-zinc-300 text-6xl mb-4"></i>
                        <h3 class="text-lg font-semibold text-zinc-700">No Products Available</h3>
                        <p class="text-zinc-400 text-sm mt-1">Please add some products from the admin panel first.</p>
                        <a href="/products/create" class="mt-6 px-5 py-2.5 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition shadow">
                            Create a Product
                        </a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
    <%- include('./partials/footer') %>